# Copy to .env and adjust as needed. All values have sane defaults in
# hybriddb/config/paths.py, so .env is optional for the default Docker setup.

# ── PostgreSQL ──
PGHOST=localhost
PGPORT=5432
PGDATABASE=hybrid_db
PGUSER=postgres
PGPASSWORD=postgres

# ── MongoDB (single-node replica set for transactions) ──
MONGO_URI=mongodb://localhost:27018/?replicaSet=rs0
MONGO_DB_NAME=hybrid_db
MONGO_BUFFER_COLL=buffer

# ── Ingestion stream (simulation server) ──
STREAM_BASE=http://127.0.0.1:8000/record
INGEST_DEFAULT_COUNT=100

# ── Type-conflict policy (how to handle un-coercible type mismatches) ──
#   adaptive = widen the field to schemaless Mongo, preserving the value
#   strict   = reject the write with a clear error (schema as a hard contract)
# Safe coercions (12345 -> "12345", "42" -> 42) always happen regardless.
HYBRIDDB_TYPE_CONFLICT_POLICY=adaptive

# ── Optional path overrides ──
# HYBRIDDB_DATA_DIR=./data
# HYBRIDDB_REPORTS_DIR=./reports
