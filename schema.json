{
  "global_key": "customer_id",

  "customer_id" : { "type": "int",     "not_null": true, "unique": true  },
  "email"       : { "type": "string",  "not_null": true, "unique": true  },
  "name"        : { "type": "string"  },
  "age"         : { "type": "int"     },
  "signup_date" : { "type": "string"  },

  "phone"    : { "type": "string"  },
  "nickname" : { "type": "string"  },

  "promo_code" : { "type": "string"  },
  "beta_flag"  : { "type": "boolean" },

  "orders": {
    "type": "array",
    "appendable": true,
    "independent_query": true,
    "fields": {
      "order_id"  : { "type": "int"    },
      "amount"    : { "type": "float"  },
      "status"    : { "type": "string" }
    }
  },

  "addresses": {
    "type": "array",
    "appendable": false,
    "independent_query": false,
    "fields": {
      "address_id" : { "type": "int"    },
      "street"     : { "type": "string" },
      "city"       : { "type": "string" },
      "country"    : { "type": "string" }
    }
  },

  "profile": {
    "type": "object",
    "appendable": false,
    "independent_query": false,
    "fields": {
      "bio"     : { "type": "string" },
      "website" : { "type": "string" }
    }
  },

  "preferences": {
    "type": "object",
    "appendable": false,
    "independent_query": false,
    "fields": {
      "theme"         : { "type": "string"  },
      "language"      : { "type": "string"  },
      "notifications" : { "type": "boolean" }
    }
  },

  "tags": {
    "type": "array",
    "appendable": true,
    "independent_query": false,
    "fields": {
      "tag" : { "type": "string" }
    }
  },

  "reviews": {
    "type": "array",
    "appendable": true,
    "independent_query": false,
    "fields": {
      "product_id" : { "type": "int"    },
      "rating"     : { "type": "int"    },
      "comment"    : { "type": "string" }
    }
  },

  "support_tickets": {
    "type": "array",
    "appendable": true,
    "independent_query": false,
    "fields": {
      "ticket_id" : { "type": "int"     },
      "issue"     : { "type": "string"  },
      "resolved"  : { "type": "boolean" }
    }
  }
}
